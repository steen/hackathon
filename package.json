{
  "name": "hackathon",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --if-present run dev",
    "build": "pnpm -r --if-present run build",
    "smoke": "bash scripts/smoke.sh",
    "test": "bash scripts/smoke.sh && pnpm -r --if-present run test",
    "lint": "eslint . --max-warnings 0",
    "check:workspace-exports": "node scripts/check-workspace-exports.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e:cli": "pnpm --filter @hackathon/e2e run e2e:cli",
    "e2e:web": "pnpm --filter web run e2e:web",
    "e2e": "pnpm run e2e:cli && pnpm run e2e:web"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^2.1.9",
    "yaml": "^2.8.4"
  }
}
