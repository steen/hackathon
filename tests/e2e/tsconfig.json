{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "allowImportingTsExtensions": false,
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "playwright/**/*.ts",
    "playwright.config.ts",
    "vitest.config.ts",
    "phase-2/**/*.ts",
    "phase-3/**/*.ts"
  ]
}
