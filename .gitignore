# Node
node_modules/
dist/
# Exception: the placeholder index.html under apps/server/internal/web/dist/
# is a tracked source file. //go:embed in apps/server/internal/web/embed.go
# requires the directory to exist at compile time; the placeholder keeps the
# embed pattern non-empty when the repo is built without first running
# `pnpm --filter web build`. Real SPA bundles copied in by the single-binary
# build script (apps/web/dist/* -> apps/server/internal/web/dist/) stay
# untracked because the parent `dist/` rule still ignores them.
!apps/server/internal/web/dist/
apps/server/internal/web/dist/*
!apps/server/internal/web/dist/index.html
.pnpm-store/
*.log
npm-debug.log*
pnpm-debug.log*

# Playwright test runs
test-results/
playwright-report/
.last-run.json

# Go
*.exe
*.test
*.out
bin/

# OS / editor
.DS_Store
.idea/
.vscode/

# Claude Code agent runtime state (skills under .claude/skills/ remain tracked)
.claude/worktrees/
.claude/test-agent/
.claude/scheduled_tasks.lock
# Per-worktree generated by .claude/scripts/write-agent-worktree-settings.sh; never committed
.claude/settings.local.json
.phase6-shots/
.dev.db
.dev.db-*
